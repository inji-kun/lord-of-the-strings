% Some defs.
% 
\newcommand{\barefootnote}[1] {%
  \begingroup
    \renewcommand{\thefootnote}{}
    \footnotetext{#1}
    \renewcommand{\thefootnote}{\arabic{footnote}}
  \endgroup
}

% Expects: 
%  #1 title 
%
\renewcommand{\title}[1] {%
  \begingroup
    \begin{center}
      \vspace{0.4in}
      \bf\huge
      \addtolength{\baselineskip}{5mm}
      #1
    \end{center}
  \endgroup
}

\newcommand{\url}[1] {%
  \barefootnote{%
    {\small e-print archive: }
    {\texttt http://lanl.arXiv.org/abs/#1} 
  }
}

\renewcommand{\author}[1] {%
  \begingroup
    \begin{center}
      \vspace{0.4in}
      \bf
      #1
      \vspace{0.2in}
    \end{center}
  \endgroup
}

% #1 Address with lines broken with \\.
% 
\newcommand{\address}[1] {%
  \begingroup
    \begin{center}
      #1
    \end{center}
  \endgroup
}

% #1 Email address with same style as addresses.
% (To go under address *only*.)
% 
\newcommand{\addressemail}[1] {%
  \begingroup
    \begin{center}
      \vskip-\baselineskip
      #1
    \end{center}
  \endgroup
}


% Cut first page at this point.
% 
\newcounter{secondpage}
%
\newcommand{\cutpage}{%
  \newpage
  \setcounter{secondpage}{\value{gfirstpage}}
  \addtocounter{secondpage}{1}
  \setcounter{page}{\value{secondpage}}
}


% Year, volume number, first page, last page.
% 
\newcounter{gfirstpage}
\newcounter{glastpage}
% 
\newcommand{\copyrightnotice}[4]{
  \leftline{\copyright~ #1 International Press}
  \leftline{Adv.\ Theor.\ Math.\ Phys. {\bf #2} (#1) #3--#4}
  \setcounter{gfirstpage}{#3}
  \setcounter{glastpage}{#4}
}


