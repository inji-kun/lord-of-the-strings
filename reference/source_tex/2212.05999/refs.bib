@article{KAZAKOV1990212,
title = {A simple solvable model of quantum field theory of open strings},
journal = {Physics Letters B},
volume = {237},
number = {2},
pages = {212-215},
year = {1990},
issn = {0370-2693},
doi = {https://doi.org/10.1016/0370-2693(90)91431-A},
url = {https://www.sciencedirect.com/science/article/pii/037026939091431A},
author = {V.A. Kazakov},
abstract = {A model of quantum field theory of open strings without any embedding (D=0) is solved. The world sheets of interacting strings are represented by dynamical planar graphs with dynamical holes of arbitrary sizes. The phenomenon of spontaneous tearing of the world sheet is noticed, which gives a singularity at zero coupling constant of string interaction. This phenomenon can be considered as a nonperturbative effect, similar to renormalons in planar field theories and is closely related to the α′ → 0 limit of string field theories.}
}

